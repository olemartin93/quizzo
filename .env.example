# Upstash Redis (REST API) — used for quiz storage and live game state.
# Create a free database at https://upstash.com (or via the Vercel Marketplace
# "Upstash" integration, which sets these automatically).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Pusher Channels — used for real-time game updates.
# Create a free app at https://pusher.com (Channels product).
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
